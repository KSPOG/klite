{
  "name": "klite-marketplace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "setup:production": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-production.ps1",
    "fix:login-ui": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/apply-login-ui-fix.ps1",
    "api:generate": "node scripts/generate-api-reference.mjs",
    "db:migrate:local": "wrangler d1 migrations apply klite-marketplace --local",
    "db:migrate:remote": "wrangler d1 migrations apply klite-marketplace --remote",
    "discord:commands": "node scripts/register-discord-commands.mjs",
    "test": "node --test test/*.test.js"
  },
  "devDependencies": {
    "wrangler": "^4.25.0"
  }
}
